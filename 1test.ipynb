    "# aspect ratios\n",
    "\n",
    "i = 1\n",
    "while True:\n",
    "    i += 1\n",
    "    mult = 32*i\n",
    "\n",
    "    print(f\"{mult}x{mult*3//4}\")\n",
    "    if mult == 2048:\n",
    "        break"
